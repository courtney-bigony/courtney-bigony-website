---
const title = "The Human Potential Index — Build AI aligned to the science of human thriving";
const description = "The most complete measure of human potential, developed with leading self-actualization scientist Dr. Scott Barry Kaufman. Download the free guide.";
const url = "https://www.courtneybigony.com/guides/hpi";
const image = "https://www.courtneybigony.com/images/og-hpi.jpg";
const pdfUrl = "/guides/HPI_Guide2026.pdf";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta http-equiv="refresh" content={`0;url=${pdfUrl}`} />
  </head>
  <body>
    <p>Redirecting to the Human Potential Index guide...</p>
  </body>
</html>
